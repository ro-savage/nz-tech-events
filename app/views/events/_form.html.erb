<%= form_with model: event do |f| %>
  <% if event.errors.any? %>
    <div class="alert alert-error">
      <strong>Please fix the following errors:</strong>
      <ul style="margin: 0.5rem 0 0 1rem;">
        <% event.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <fieldset>
    <legend>Event Details</legend>

    <label for="event_title">
      Title *
      <%= f.text_field :title, required: true, placeholder: "e.g., Auckland JavaScript Meetup" %>
    </label>

    <label for="event_event_type">
      Event Type *
      <%= f.select :event_type, event_type_options, { prompt: "Select type..." }, { required: true } %>
    </label>

    <label for="event_description">
      Description *
    </label>
    <%= f.rich_text_area :description, required: true %>

    <label for="event_short_summary">
      Short Summary <small class="text-muted">(optional, shown on event list)</small>
      <%= f.text_area :short_summary, rows: 2, maxlength: 500, placeholder: "Brief summary for the events list. If blank, the first 500 characters of the description will be used." %>
    </label>
  </fieldset>

  <% unless event.persisted? %>
    <fieldset>
      <legend>Dates</legend>
      <p class="text-muted" style="margin-bottom: var(--pico-spacing);"><small>Add one or more dates. A separate event will be created for each date, sharing all other details above.</small></p>

      <div id="dates-container">
        <% (@submitted_dates || [ { "start_date" => Date.tomorrow.to_s } ]).each_with_index do |date, i| %>
          <div class="date-row" data-date-index="<%= i %>" style="margin-bottom: var(--pico-spacing); padding-bottom: var(--pico-spacing); border-bottom: 1px solid var(--pico-muted-border-color);">
            <div class="grid">
              <label>
                Start Date *
                <input type="date" name="event[dates][<%= i %>][start_date]"
                       value="<%= date["start_date"] %>" required class="date-start-input">
              </label>

              <label>
                End Date <small class="text-muted">(multi-day events)</small>
                <input type="date" name="event[dates][<%= i %>][end_date]"
                       value="<%= date["end_date"] %>" class="date-end-input">
              </label>
            </div>

            <div class="grid" style="grid-template-columns: 1fr 1fr auto; align-items: center;">
              <label>
                Start Time
                <input type="time" name="event[dates][<%= i %>][start_time]"
                       value="<%= date["start_time"] %>">
              </label>

              <label>
                End Time
                <input type="time" name="event[dates][<%= i %>][end_time]"
                       value="<%= date["end_time"] %>">
              </label>
               <button type="button" class="remove-date-btn outline secondary"
                        data-date-index="<%= i %>"
                        style="padding: 0.5rem 0.75rem;">
                  &times;
                </button>
            </div>
          </div>
        <% end %>
      </div>

      <button type="button" id="add-date-btn" class="outline secondary" style="margin-top: var(--pico-spacing);">
        + Add Another Date
      </button>
    </fieldset>
  <% else %>
    <fieldset>
      <legend>Date & Time</legend>

      <div class="grid">
        <label for="event_start_date">
          Start Date *
          <%= f.date_field :start_date, required: true %>
        </label>

        <label for="event_end_date">
          End Date <small class="text-muted">(multi-day events)</small>
          <%= f.date_field :end_date %>
        </label>
      </div>

      <div class="grid">
        <label for="event_start_time">
          Start Time
          <%= f.time_field :start_time %>
        </label>

        <label for="event_end_time">
          End Time
          <%= f.time_field :end_time %>
        </label>
      </div>
    </fieldset>
  <% end %>

  <fieldset>
    <legend>Location(s)</legend>

    <div id="locations-container">
      <%= f.fields_for :event_locations do |loc| %>
        <%= render "event_location_fields", f: loc %>
      <% end %>
    </div>

    <button type="button" id="add-location-btn" class="outline secondary" style="margin-top: var(--pico-spacing);">
      + Add Another Location
    </button>

    <label for="event_address" style="margin-top: var(--pico-spacing);">
      Address / Venue <small class="text-muted">(optional, for primary location)</small>
      <%= f.text_area :address, rows: 2, placeholder: "e.g., GridAKL, 12 Madden Street, Auckland" %>
    </label>
  </fieldset>

  <fieldset>
    <legend>Additional Info</legend>

    <label for="event_cost">
      Cost <small class="text-muted">(leave blank for free events)</small>
      <%= f.text_field :cost, placeholder: "e.g., Free, $20, $50-100, Koha" %>
    </label>

    <label for="event_registration_url">
      Registration Link <small class="text-muted">(optional)</small>
      <%= f.url_field :registration_url, placeholder: "https://..." %>
    </label>

    <% if Current.user&.admin? %>
      <label for="event_source">
        Source <small class="text-muted">(optional attribution shown on the event page)</small>
        <%= f.text_field :source, placeholder: "e.g., Tech Community Newsletter" %>
      </label>

      <label for="event_source_url">
        Source URL <small class="text-muted">(optional)</small>
        <%= f.url_field :source_url, placeholder: "https://..." %>
      </label>
    <% end %>
  </fieldset>

  <div class="flex gap-1">
    <button type="submit"><%= event.persisted? ? "Update Event" : "Create Event" %></button>
    <a href="<%= event.persisted? ? event_path(event) : root_path %>" role="button" type="button" class="outline secondary">Cancel</a>
  </div>
<% end %>

<script type="text/javascript" nonce="<%= content_security_policy_nonce %>">
  (function() {
    const citiesByRegion = <%= cities_json %>;
    const locationsContainer = document.getElementById('locations-container');
    const addLocationBtn = document.getElementById('add-location-btn');
    const datesContainer = document.getElementById('dates-container');
    const addDateBtn = document.getElementById('add-date-btn');

    let locationIndex = document.querySelectorAll('.location-row').length;
    let dateIndex = datesContainer ? datesContainer.querySelectorAll('.date-row').length : 0;

    // Generate region options HTML
    const regionOptionsHtml = '<option value="">Select region...</option>' +
      <%= region_options.map { |label, value| "<option value=\"#{value}\">#{j(label)}</option>" }.join.to_json.html_safe %>;

    // ── Location management ──────────────────────────────────────────

    function createLocationRow(index) {
      return `
        <div class="location-row" data-location-index="${index}">
          <div class="grid" style="grid-template-columns: 1fr 1fr auto; align-items: center;">
            <input type="hidden" name="event[event_locations_attributes][${index}][position]" value="${index}">
            <input type="hidden" name="event[event_locations_attributes][${index}][_destroy]" value="false" class="destroy-field">

            <label>
              Region *
              <select name="event[event_locations_attributes][${index}][region]"
                      required class="location-region-select" data-index="${index}">
                ${regionOptionsHtml}
              </select>
            </label>

            <label>
              City
              <select name="event[event_locations_attributes][${index}][city]"
                      class="location-city-select" data-index="${index}">
                <option value="">Select city...</option>
              </select>
            </label>
            <button type="button" class="remove-location-btn outline secondary"
                    data-index="${index}"
                    style="padding: 0.5rem 0.75rem;">
              &times;
            </button>
          </div>
        </div>
      `;
    }

    if (addLocationBtn) {
      addLocationBtn.onclick = function() {
        const html = createLocationRow(locationIndex);
        locationsContainer.insertAdjacentHTML('beforeend', html);
        locationIndex++;
        attachLocationHandlers();
      };
    }

    function updateCityDropdown(regionSelect) {
      const index = regionSelect.dataset.index;
      const citySelect = document.querySelector(`.location-city-select[data-index="${index}"]`);
      const region = regionSelect.value;
      const cities = citiesByRegion[region] || [];

      citySelect.innerHTML = '<option value="">Select city...</option>';
      cities.forEach(function(city) {
        const option = document.createElement('option');
        option.value = city;
        option.textContent = city;
        citySelect.appendChild(option);
      });
    }

    function removeLocation(btn) {
      const index = btn.dataset.index;
      const row = document.querySelector(`.location-row[data-location-index="${index}"]`);

      const idField = row.querySelector('input[name*="[id]"]');
      if (idField) {
        row.querySelector('.destroy-field').value = 'true';
        row.style.display = 'none';
      } else {
        row.remove();
      }
    }

    function attachLocationHandlers() {
      document.querySelectorAll('.location-region-select').forEach(function(select) {
        select.onchange = function() { updateCityDropdown(this); };
      });

      document.querySelectorAll('.remove-location-btn').forEach(function(btn) {
        btn.onclick = function() { removeLocation(this); };
      });
    }

    attachLocationHandlers();

    // ── Multi-date management (create form only) ─────────────────────

    function createDateRow(index) {
      return `
        <div class="date-row" data-date-index="${index}" style="margin-bottom: var(--pico-spacing); padding-bottom: var(--pico-spacing); border-bottom: 1px solid var(--pico-muted-border-color);">
          <div class="grid">
            <label>
              Start Date *
              <input type="date" name="event[dates][${index}][start_date]" required class="date-start-input">
            </label>
            <label>
              End Date <small class="text-muted">(multi-day events)</small>
              <input type="date" name="event[dates][${index}][end_date]" class="date-end-input">
            </label>
          </div>
          <div class="grid" style="grid-template-columns: 1fr 1fr auto; align-items: center;">
            <label>
              Start Time
              <input type="time" name="event[dates][${index}][start_time]">
            </label>
            <label>
              End Time
              <input type="time" name="event[dates][${index}][end_time]">
            </label>
            <button type="button" class="remove-date-btn outline secondary"
                      data-date-index="${index}"
                      style="padding: 0.5rem 0.75rem;">
                &times;
              </button>
          </div>
        </div>
      `;
    }

    function updateRemoveDateButtons() {
      if (!datesContainer) return;
      const rows = datesContainer.querySelectorAll('.date-row');
      rows.forEach(function(row) {
        const btn = row.querySelector('.remove-date-btn');
        if (btn) btn.style.display = rows.length <= 1 ? 'none' : '';
      });
    }

    function attachDateRowHandlers(row) {
      const startInput = row.querySelector('.date-start-input');
      const endInput = row.querySelector('.date-end-input');
      const removeBtn = row.querySelector('.remove-date-btn');

      if (startInput && endInput) {
        let previousStart = startInput.value;
        startInput.addEventListener('change', function() {
          if (!endInput.value || endInput.value === previousStart) {
            endInput.value = this.value;
          }
          previousStart = this.value;
        });
      }

      if (removeBtn) {
        removeBtn.addEventListener('click', function() {
          row.remove();
          updateRemoveDateButtons();
        });
      }
    }

    if (datesContainer) {
      datesContainer.querySelectorAll('.date-row').forEach(attachDateRowHandlers);
      updateRemoveDateButtons();
    }

    if (addDateBtn && datesContainer) {
      addDateBtn.addEventListener('click', function() {
        const html = createDateRow(dateIndex);
        datesContainer.insertAdjacentHTML('beforeend', html);
        const newRow = datesContainer.querySelector(`.date-row[data-date-index="${dateIndex}"]`);
        attachDateRowHandlers(newRow);
        dateIndex++;
        updateRemoveDateButtons();
      });
    }
  })();
</script>
